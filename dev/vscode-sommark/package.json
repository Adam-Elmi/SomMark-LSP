{
  "name": "sommark-lsp-dev",
  "displayName": "SomMark Language Server (dev)",
  "description": "Dev build — points to local SomMark-LSP server.",
  "version": "0.0.1",
  "publisher": "Adam-Elmi",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "icon": "icons/sommark.png",
  "contributes": {
    "languages": [
      {
        "id": "sommark",
        "aliases": [
          "SomMark",
          "sommark"
        ],
        "extensions": [
          ".smark"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sommark-icon.svg",
          "dark": "./icons/sommark-icon.svg"
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}

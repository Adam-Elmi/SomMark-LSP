  "repository": {
    "comments": {
      "begin": "#",
      "end": "$",
      "name": "comment.line.number-sign.sommark"
    },
    "brackets": {
      "patterns": [
        { "match": "[\\[\\](){}]", "name": "punctuation.bracket.sommark" }
      ]
    },
    "at-block-generic": {
      "begin": "(@_)([a-zA-Z0-9_-]+)(_@)",
      "beginCaptures": {
        "1": { "name": "keyword.other.sommark" },
        "2": { "name": "entity.name.tag.sommark" },
        "3": { "name": "keyword.other.sommark" }
      },
      "end": "(@_)(\\s*end\\s*)(_@)",
      "endCaptures": {
        "1": { "name": "keyword.other.sommark" },
        "2": { "name": "keyword.control.end.sommark" },
        "3": { "name": "keyword.other.sommark" }
      }
    },
    "at-block-style-override": {
      "begin": "(@_[Ss]tyle_@)(\\s*(?:\\[[^\\]]*\\])?\\s*:\\s*)([a-zA-Z0-9_-]+)(\\s*;)",
      "beginCaptures": {
          "1": { "name": "keyword.other.sommark" },
          "2": { "name": "punctuation.separator.sommark" },
          "3": { "name": "variable.parameter.sommark" },
          "4": { "name": "punctuation.terminator.sommark" }
      },
      "end": "(@_)(\\s*end\\s*)(_@)",
      "patterns": [
          { "include": "source.css" },
          { "include": "source.scss" },
          { "include": "source.sass" },
          { "include": "source.less" },
          { "include": "source.stylus" }
      ]
    },

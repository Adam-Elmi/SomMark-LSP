{
  "name": "sommark-lsp",
  "displayName": "SomMark Language Server",
  "description": "Real-time diagnostics, code formatting, and semantic highlighting for SomMark files.",
  "version": "1.1.1",
  "publisher": "Adam-Elmi",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "icon": "icons/sommark.png",
  "contributes": {
    "languages": [
      {
        "id": "sommark",
        "aliases": [
          "SomMark",
          "sommark"
        ],
        "extensions": [
          ".smark"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sommark-icon.svg",
          "dark": "./icons/sommark-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "sommark",
        "scopeName": "source.sommark",
        "path": "./syntaxes/sommark.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.css": "css",
          "source.json": "json",
          "source.go": "go",
          "source.lua": "lua",
          "source.python": "python",
          "source.rust": "rust",
          "text.html.basic": "html",
          "source.cpp": "cpp",
          "source.c": "c",
          "source.shell": "shellscript",
          "source.sql": "sql",
          "source.yaml": "yaml",
          "text.html.markdown": "markdown",
          "source.dockerfile": "dockerfile",
          "source.makefile": "makefile",
          "text.xml": "xml",
          "source.java": "java",
          "source.cs": "csharp",
          "source.ruby": "ruby",
          "source.php": "php",
          "source.js.jsx": "javascriptreact",
          "source.ts.tsx": "typescriptreact",
          "source.swift": "swift",
          "source.kotlin": "kotlin",
          "source.dart": "dart",
          "source.clojure": "clojure",
          "source.elixir": "elixir",
          "source.haskell": "haskell",
          "source.scala": "scala",
          "source.julia": "julia",
          "source.r": "r",
          "source.perl": "perl",
          "source.powershell": "powershell",
          "source.objc": "objective-c",
          "source.objcpp": "objective-cpp",
          "source.ini": "ini",
          "source.toml": "toml",
          "text.tex.latex": "latex",
          "source.graphql": "graphql",
          "source.proto": "protobuf",
          "source.nginx": "nginx",
          "source.svelte": "svelte",
          "source.vue": "vue",
          "source.astro": "astro",
          "source.scss": "scss",
          "source.sass": "sass",
          "source.less": "less",
          "source.stylus": "stylus",
          "source.coffee": "coffeescript",
          "source.groovy": "groovy",
          "source.puppet": "puppet",
          "source.terraform": "terraform",
          "source.hcl": "hcl",
          "source.prisma": "prisma",
          "source.elm": "elm",
          "source.erlang": "erlang",
          "source.ocaml": "ocaml",
          "source.fsharp": "fsharp",
          "source.asp.vb.net": "vb",
          "source.matlab": "matlab",
          "source.fortran": "fortran",
          "source.raku": "raku",
          "source.diff": "diff",
          "text.html.jinja": "jinja",
          "text.html.twig": "twig",
          "text.html.liquid": "liquid",
          "text.pug": "pug",
          "text.haml": "haml"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Adam-Elmi/SomMark-LSP.git"
  },
  "dependencies": {
    "sommark": "^3.3.4",
    "sommark-lsp": "^1.0.2",
    "vscode-languageclient": "^9.0.1"
  }
}

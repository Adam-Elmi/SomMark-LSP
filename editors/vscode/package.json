{
  "name": "sommark-lsp",
  "displayName": "SomMark Language Server",
  "description": "Real-time diagnostics, code formatting, and semantic highlighting for SomMark files.",
  "version": "1.2.0",
  "publisher": "Adam-Elmi",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "icon": "icons/sommark.png",
  "contributes": {
    "languages": [
      {
        "id": "sommark",
        "aliases": [
          "SomMark",
          "sommark"
        ],
        "extensions": [
          ".smark"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sommark-icon.svg",
          "dark": "./icons/sommark-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "sommark",
        "scopeName": "source.sommark",
        "path": "./syntaxes/sommark.tmLanguage.json",
        "embeddedLanguages": {
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.css": "css",
          "source.json": "json",
          "text.html.basic": "html",
          "source.yaml": "yaml",
          "text.html.markdown": "markdown",
          "text.xml": "xml",
          "source.js.jsx": "javascriptreact",
          "source.ts.tsx": "typescriptreact",
          "source.scss": "scss",
          "source.sass": "sass",
          "source.less": "less",
          "source.stylus": "stylus"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Adam-Elmi/SomMark-LSP.git"
  },
  "dependencies": {
    "sommark": "^4.0.0",
    "sommark-lsp": "^1.1.0",
    "vscode-languageclient": "^9.0.1"
  }
}

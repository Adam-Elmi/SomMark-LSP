{
  "name": "sommark-lsp",
  "displayName": "SomMark Language Server",
  "description": "Real-time diagnostics, code formatting, and semantic highlighting for SomMark files.",
  "version": "1.0.1",
  "publisher": "Adam-Elmi",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:sommark"
  ],
  "icon": "icons/sommark.png",
  "contributes": {
    "languages": [
      {
        "id": "sommark",
        "aliases": [
          "SomMark",
          "sommark"
        ],
        "extensions": [
          ".smark"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sommark-icon.svg",
          "dark": "./icons/sommark-icon.svg"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Adam-Elmi/SomMark-LSP.git"
  },
  "dependencies": {
    "sommark": "^3.3.2",
    "sommark-lsp": "latest",
    "vscode-languageclient": "^9.0.1"
  }
}